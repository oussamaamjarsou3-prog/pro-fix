  "drivingExperience": {
    "es": {
      "handling": {
        "summary": "El RS3 se siente ágil y seguro, con un chasis que aprovecha el quattro y el RS torque splitter para rotar en curvas.",
        "bodyRoll": "Controlado gracias a la suspensión RS. En modo Comfort permite algo de balanceo para mejorar confort urbano.",
        "steeringFeel": "Dirección progresiva y bien comunicada, con asistencia variable que se endurece progresivamente en modos RS."
      },
      "performanceFeel": {
        "acceleration": "Inmediata y sonora. El turbo entra pronto y empuja de forma constante hasta las 7.000 rpm.",
        "braking": "Discos de 375 mm delanteros con pinzas de seis pistones; mordida potente y buena resistencia a la fatiga.",
        "transmission": "La transmisión S tronic de 7 velocidades cambia con rapidez y suavidad, especialmente en modo manual.",
        "sound": "El sonido del 5 cilindros es el protagonista: ronco, metálico y con estallidos al cambiar de marcha."
      },
      "dailyDriving": {
        "summary": "A pesar de su carácter deportivo, el RS3 puede usarse a diario con relativa comodidad.",
        "comfort": "El modo Comfort suaviza la suspensión y la dirección, haciendo el RS3 más civilizado en trayectos cotidianos.",
        "visibility": "Buena visibilidad frontal y lateral; los pilares traseros son algo gruesos para maniobras de aparcamiento."
      }
    },
    "en": {
      "handling": {
