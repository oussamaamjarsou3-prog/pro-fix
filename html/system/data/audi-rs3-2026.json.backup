    "ar": {
      "summary": "تصميم آر إس 3 عدواني لكن أنيق، مع شبكة أعرض وفتحات تهوية كبيرة وتفاصيل آر إس خاصة.",
      "stylingNotes": [
        "الشبكة سينغل فرايم اللامعة باللون الأسود مع شعار آر إس هي توقيع الهوية الأمامية.",
        "قوس عجلات أعرض ومصدود أعمق تميزها عن أي 3 التقليدية.",
        "مخارج العادم البيضاوية من الفولاذ المقاوم للصدأ والموزع الخلفي لا تخطئانها بأنها آر إس."
      ],
      "dimensionsContext": "يبلغ طولها 4,505 ملم وعرضها 1,813 ملم وارتفاعها 1,425 ملم، مع قاعدة عجلات 2,630 ملم.",
      "aerodynamics": {
        "dragCoefficient": 0.32,
        "activeAero": "جناح خلفي ثابت يوازن بين الحمل الأيروديناميكي والجمالية الرياضية.",
        "frontSpoiler": "جناح أمامي بشفة أكثر بروزًا لتقليل تدفق الهواء أسفل السيارة.",
        "rearDiffuser": "موزع خلفي وظيفي يحسن سحب الهواء من أسفل الهيكل."
      },
      "lighting": {
        "headlights": "مصابيح مصابيح ليد ماتريكس بتوقيع ضوئي خاص وشعاع عالي تكيفي.",
        "taillights": "أضواء ليد خلفية مع حركة دخول وإشارات انعطاف متسلسلة.",
        "signature": "أضواء نهارية ليد بتأثير ثلاثي الأبعاد وأضواء رجوع بحركة خاصة."
      },
      "wheels": {
        "standard": "19 بوصة بتصميم 10 أضلاع من سبيكة خفيفة، بلمسة نهائية باللون الأسود الرمادي.",
        "optional": [
          "20 بوصة بتصميم آر إس مع إطارات 265/30 20",
          "فرامل سيراميك مع مكابس حمراء اختيارية"
        ]
      },
