  "interiorText": {
    "es": {
      "interior-quality": {
        "title": "Materiales RS",
        "desc": "Cuero Nappa, Dinamica microfibra y aluminio cepillado con costuras a contraste."
      },
      "infotainment": {
        "title": "MMI y Virtual Cockpit",
        "desc": "Pantalla táctil central de 10.1 pulgadas y cuadro de instrumentos digital de 12.3 pulgadas."
      },
      "sound-system": {
        "title": "Bang & Olufsen",
        "desc": "Sistema de 15 altavoces con 705 W y sonido envolvente de alta fidelidad."
      },
      "ambient-lighting": {
        "title": "Iluminación ambiental",
        "desc": "30 colores con ambientes RS y paneles iluminados en salpicadero y puertas."
      }
    },
    "en": {
      "interior-quality": {
        "title": "RS materials",
        "desc": "Nappa leather, Dinamica microfibre and brushed aluminium with contrast stitching."
      },
      "infotainment": {
        "title": "MMI and Virtual Cockpit",
        "desc": "10.1-inch central touchscreen and 12.3-inch digital instrument cluster."
      },
      "sound-system": {
        "title": "Bang & Olufsen",
        "desc": "15-speaker system with 705 W and high-fidelity surround sound."
      },
      "ambient-lighting": {
        "title": "Ambient lighting",
        "desc": "30 colours with RS ambiences and illuminated panels on dashboard and doors."
      }
    },
    "fr": {
      "interior-quality": {
        "title": "Matériaux RS",
        "desc": "Cuir Nappa, microfibre Dinamica et aluminium brossé avec surpiqûres contrastées."
      },
      "infotainment": {
        "title": "MMI et Virtual Cockpit",
        "desc": "Écran tactile central 10,1 pouces et tableau de bord numérique 12,3 pouces."
      },
      "sound-system": {
        "title": "Bang & Olufsen",
        "desc": "Système 15 haut-parleurs avec 705 W et son surround haute fidélité."
      },
      "ambient-lighting": {
        "title": "Éclairage ambiant",
        "desc": "30 couleurs avec ambiances RS et panneaux éclairés sur tableau de bord et portes."
      }
    },
    "ar": {
      "interior-quality": {
        "title": "مواد آر إس",
        "desc": "جلد نابا وألياف ديناميكا الدقيقة وألومنيوم مصقول مع خياطة متباينة."
      },
      "infotainment": {
        "title": "إم إم آي وافتراضي كوكبيت",
        "desc": "شاشة لمس مركزية 10.1 بوصة ولوحة عدادات رقمية 12.3 بوصة."
      },
      "sound-system": {
        "title": "بانغ أند أولوفسن",
        "desc": "نظام 15 مكبر صوت بقوة 705 واط وصوت محيطي عالي الدقة."
      },
      "ambient-lighting": {
        "title": "الإضاءة المحيطة",
        "desc": "30 لونًا مع أجواء آر إس وألواح مضاءة على لوحة القيادة والأبواب."
      }
    }
