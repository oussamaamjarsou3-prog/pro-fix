  "problems": {
    "es": [
      "Cadena de distribución: elongación a los 80.000 km",
      "Caja ZF 8HP: tirones en frío (bloqueo convertidor)",
      "Turbo híbrido: costoso si falla (más de 8.000 €)",
      "Frenos carbocerámicos: desgaste prematuro en ciudad",
      "Suspensión trasera: bujes de goma a los 60.000 km"
    ],
    "en": [
      "Timing chain: elongation at 80,000 km",
      "ZF 8HP transmission: cold jerks (converter lockup)",
      "Hybrid turbo: expensive if it fails (over €8,000)",
      "Carbon-ceramic brakes: premature wear in city",
      "Rear suspension: rubber bushings at 60,000 km"
    ],
    "fr": [
      "Chaîne de distribution : élongation à 80 000 km",
      "Boîte ZF 8HP : à-coups à froid (blocage convertisseur)",
