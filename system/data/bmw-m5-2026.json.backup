        "gripLevels": "استثنائية. ينظم الدفع الرباعي العزم بذكاء، مما يسمح بالانطلاق الآمن حتى مع 1,000 نيوتن متر.",
        "rideQuality": "في وضع الراحة، مريحة بشكل مدهش لسيدان رياضية. في وضع الرياضة تصبح صلبة وتواصلية."
      },
      "performanceFeel": {
        "acceleration": "وحشية وفورية. عزم 1,000 نيوتن متر متاح من سرعات منخفضة، مما يدفع أم 5 بعنف منضبط.",
        "braking": "أقراص الفرامل الأمامية السيراميكية مقاس 400 ملم تقدم قوة كبح فعالة ومقاومة للتآكل.",
        "sound": "يُنتج محرك محرك 8 أسطوانات التوين تيربو صوتًا عميقًا ومعدنيًا؛ في وضع الرياضة يصبح العادم أكثر عدوانية.",
        "transmission": "ناقل الحركة إم ستيبترونيك بثماني سرعات يتحول بسلاسة في الوضع الأوتوماتيكي وبسرعة في الوضع اليدوي."
      },
      "dailyDriving": {
        "comfort": "ممتاز للرحلات الطويلة. مقاعد أم سبورت بضبط كهربائي وتدفئة وتبريد تزيل التعب.",
        "visibility": "رؤية جيدة للأمام؛ الكاميرا المحيطية 360° والمستشعرات تعوض النقاط العمياء.",
        "parking": "قابلة للمناورة بالنسبة لحجمها بفضل مستشعرات الوقوف ومساعد المناورة.",
        "motorway": "هنا تشعر بأنها في بيئتها. مثبت السرعة التكيفي ومساعد المسار والقوة الوفيرة تتيح السفر دون جهد."
      }
