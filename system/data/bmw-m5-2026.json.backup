  "ownership": {
    "es": {
      "dailyUsability": "Berlina de 5 plazas con tracción total y modos de conducción adaptativos. Cómodo para viajes largos y usable a diario.",
      "reliability": "Buena fiabilidad general si se sigue el mantenimiento oficial. El sistema híbrido añade complejidad y costes de reparación elevados.",
      "longTrips": "Excelente para autopista: confort, potencia de adelantamiento y autonomía híbrida. Maletero de 466 L.",
      "cityDriving": "Manejable en ciudad a pesar del tamaño. El modo eléctrico permite desplazamientos cortos sin emisiones.",
      "commonIssues": [
        {
          "issue": "Desgaste prematuro de neumáticos traseros por el alto par y la tracción total",
          "frequency": "common",
          "cost": "1.800 € cada 15.000-20.000 km"
        },
        {
          "issue": "Ruido de la suspensión adaptativa M en frío durante los primeros segundos",
          "frequency": "occasional",
          "cost": "Normalmente resuelto con lubricación, ~150 €"
        },
        {
          "issue": "Problemas menores con BMW OS tras actualizaciones de software",
          "frequency": "occasional",
          "cost": "Resuelto por garantía o actualización OTA"
        }
      ],
      "ownerReviews": [
        {
          "quote": "Llevo 40.000 km con mi M5 y sigue emocionándome cada vez que arranco. El consumo es alto, pero la sonrisa que me saca vale cada céntimo.",
          "author": "Marcus T.",
          "location": "Munich, Alemania",
          "ownsSince": "2024",
          "rating": 9.5
        },
        {
          "quote": "Lo utilizo para viajes de negocios y escapadas de fin de semana. En modo Comfort es tan silencioso como un Serie 7, pero presionas M Mode y se transforma.",
          "author": "Sophie L.",
          "location": "Lyon, Francia",
          "ownsSince": "2025",
          "rating": 9
        }
      ],
      "satisfactionRating": 9.2
    },
    "en": {
      "dailyUsability": "5-seat sedan with AWD and adaptive driving modes. Comfortable for long trips and daily use.",
      "reliability": "Good overall reliability if official maintenance is followed. The hybrid system adds complexity and high repair costs.",
      "longTrips": "Excellent for highway: comfort, overtaking power and hybrid range. 466 L trunk.",
      "cityDriving": "Manageable in city despite size. Electric mode allows short zero-emission trips.",
      "commonIssues": [
        {
          "issue": "Premature rear tyre wear due to high torque and all-wheel drive",
          "frequency": "common",
          "cost": "€1,800 every 15,000-20,000 km"
